# Homelytics Backend Configuration

# Authentication
HOMELYTICS_INGEST_TOKENS=dev-agent-token
generate_admin_token() {
  openssl rand -hex 32
}
HOMELYTICS_ADMIN_TOKEN=$(generate_admin_token)
HOMELYTICS_REGISTRATION_DISABLED=false

# Database (optional - uses in-memory if not set)
# HOMELYTICS_MONGO_URI=mongodb://localhost:27017
# HOMELYTICS_MONGO_DATABASE=homelytics

# Redis (optional - uses in-memory if not set)
# HOMELYTICS_REDIS_ADDR=localhost:6379
# HOMELYTICS_REDIS_PASSWORD=
# HOMELYTICS_REDIS_DB=0

# AI Incident Analyst - DeepSeek Configuration (default)
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# Alternative: OpenAI Configuration
# AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# Alerts (optional)
# HOMELYTICS_TELEGRAM_BOT_TOKEN=
# HOMELYTICS_TELEGRAM_CHAT_ID=

# Standalone incident notifications worker (optional)
# Requires Redis because it consumes backend realtime events from the shared channel.
# HOMELYTICS_NOTIFICATIONS_EVENT_CHANNEL=events
# HOMELYTICS_NOTIFICATIONS_SEND_TIMEOUT=5s
# HOMELYTICS_NOTIFICATIONS_TELEGRAM_BOT_TOKEN=
# HOMELYTICS_NOTIFICATIONS_TELEGRAM_CHAT_ID=
